# 이 파일을 복사해서 .env 로 저장한 뒤 실제 키를 입력하세요.
# .env 파일은 절대 Git에 올리지 마세요 (.gitignore에 등록되어 있음)
# Vercel 배포 시에는 .env 대신 Vercel 대시보드 → Settings → Environment Variables에 입력하세요.

# ── Supabase (데이터베이스 — 백엔드용) ──────────────────────────────────────────
# https://supabase.com → 프로젝트 → Settings → API
SUPABASE_URL=https://여기에_supabase_프로젝트_url
SUPABASE_ANON_KEY=여기에_anon_public_키

# ── Supabase (프론트엔드용 — Vercel 환경변수에 VITE_ 접두사로 추가) ───────────
# Vercel 대시보드 → Settings → Environment Variables 에 아래 두 항목 추가
VITE_SUPABASE_URL=https://여기에_supabase_프로젝트_url
VITE_SUPABASE_ANON_KEY=여기에_anon_public_키
# ※ 위 두 값은 SUPABASE_URL, SUPABASE_ANON_KEY 와 동일한 값입니다.

# ── OpenAI API ────────────────────────────────────────────────────────────────
# https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-여기에_API_키를_붙여넣기

# ── Gmail SMTP (이메일 알림) ──────────────────────────────────────────────────
# Gmail → 계정 → 보안 → 2단계 인증 → 앱 비밀번호
GMAIL_ADDRESS=your_email@gmail.com
GMAIL_APP_PASSWORD=여기에_앱_비밀번호_입력

# ── 오픈뱅킹 API (Phase 2, 현재 미사용) ───────────────────────────────────────
OPENBANKING_CLIENT_ID=
OPENBANKING_CLIENT_SECRET=
